# Supabase (requerido)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Cloudflare Turnstile (opcional - protección anti-bot para formularios)
# Obtén tus keys en: https://dash.cloudflare.com/?to=/:account/turnstile
# NEXT_PUBLIC_TURNSTILE_SITE_KEY=0x4AAAA...
# TURNSTILE_SECRET_KEY=0x4AAAA...

# Cloudflare R2 (opcional - almacenamiento de imágenes alternativo)
# NEXT_PUBLIC_R2_PUBLIC_URL=https://pub-xxxx.r2.dev
# R2_ACCESS_KEY_ID=your_access_key_id
# R2_SECRET_ACCESS_KEY=your_secret_access_key
# R2_BUCKET_NAME=detras-del-espejo

# Site URL (opcional - para sitemap y robots)
# NEXT_PUBLIC_SITE_URL=https://detrasdelespejo.com
